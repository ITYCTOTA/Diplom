    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2"
  }
